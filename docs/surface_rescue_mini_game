}

function saveHighScore(score) {
  try { localStorage.setItem(HS_KEY, score); } catch(e) {}
}

function updateSplashHighScore() {
  const hs = getHighScore();
  const wrap = document.getElementById('splashHighScore');
  const val = document.getElementById('splashHSValue');
  if(hs > 0 && wrap && val) {
    val.textContent = hs + '/20';
    wrap.style.display = 'flex';
  }
}

function replayGame() {
  document.getElementById('screenComplete').classList.remove('active');
  document.getElementById('newBestBadge').classList.remove('show');
  startGame();
}

function goToSplash() {
  document.getElementById('screenComplete').classList.remove('active');
  document.getElementById('satBarWrap').style.display = 'none';
  document.getElementById('roundsWrap').style.display = 'none';
  document.getElementById('scoreDisplay').textContent = '00';
  document.getElementById('screenSplash').classList.add('active');
  updateSplashHighScore();
}

function showSplash(){
  document.getElementById('screenIntro').classList.remove('active');
  document.getElementById('screenSplash').classList.add('active');
}

function showIntro(){
  document.getElementById('screenSplash').classList.remove('active');
  document.getElementById('screenIntro').classList.add('active');
}

function getMarvKey(stageType, sat) {
  if(stageType === 'clean' || stageType === 'mask') return 'instruct';
  if(stageType === 'sand' || stageType === 'technique') {
    const roundMarvKeys = ['assess','confident','confident','assess','confident'];
    return roundMarvKeys[state.round] || 'confident';
  }
  return 'confident';
}

function getMarvBysat(sat) {
  const pct = (sat / 10) * 100;
  if(pct > 60) return 'confident';
  if(pct > 30) return 'nervous';
  return 'angry';
}

function startGame(){
  // Hide whichever pre-game screen is active
  document.getElementById('screenSplash').classList.remove('active');
  document.getElementById('screenIntro').classList.remove('active');
  document.getElementById('screenGame').classList.add('active');
  // Reveal chrome elements now game has started
  document.getElementById('satBarWrap').style.display = 'block';
  document.getElementById('roundsWrap').style.display = 'flex';
  state={round:0,stage:0,score:0,disabledOpts:[],stageComplete:false,roundComplete:false};
  SAT=10;
  updateScore();
  loadRound();
}


function loadRound(){
  state.stage=0;state.stageComplete=false;state.roundComplete=false;
  state.disabledOpts=[];
  updateDots();
  loadStage();
}

function loadStage(){
  state.stageComplete=false;state.disabledOpts=[];state.shuffledOptions=[];
  const round=ROUNDS[state.round];
  const stageData=round.stages[state.stage];

  // MARV speech
  document.getElementById('marvSpeech').textContent=stageData.marv;
  setMarv('marvFrame', getMarvKey(stageData.type, SAT));

  // Stage pills
  const stageWrap=document.getElementById('stagesWrap');
  stageWrap.innerHTML='';
  round.stages.forEach((s,i)=>{
    const btn=document.createElement('div');
    btn.className='stage-btn';
    if(i<state.stage)btn.classList.add('done');
    else if(i===state.stage)btn.classList.add('active');
    btn.textContent=s.label;
    stageWrap.appendChild(btn);
  });

  // Surface
  document.getElementById('surfName').textContent=round.substrate;
  document.getElementById('stageInd').textContent='Stage '+(state.stage+1)+': '+stageData.label.toUpperCase();
  resizeCanvas();
  drawSurface(round.surfaceType,round.surfaceColor,false);
  document.getElementById('rescueOverlay').classList.remove('show');

  // Defect card
  document.getElementById('defectChip').textContent=stageData.label.toUpperCase();
  document.getElementById('defectTitle').textContent=round.substrate;
  document.getElementById('defectDesc').textContent='';
  document.getElementById('stagePrompt').textContent=stageData.prompt;

  // Sat bar
  updateSatBar();

  // Reset feedback + next
  const fb=document.getElementById('feedbackCard');
  fb.className='feedback-card';
  document.getElementById('nextBtn').className='next-btn';

  renderOptions();
}

function shuffleArray(arr) {
  const a = [...arr];
  for(let i = a.length-1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i+1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function renderOptions(){
  const stageData=ROUNDS[state.round].stages[state.stage];
  const grid=document.getElementById('optsGrid');
  grid.innerHTML='';
  // Shuffle options so correct answer appears in a random position each time
  if(!state.shuffledOptions) state.shuffledOptions = [];
  if(state.shuffledOptions.length === 0) {
    state.shuffledOptions = shuffleArray(stageData.options.map((_,i) => i));
  }
  state.shuffledOptions.forEach((origIdx) => {
    const opt = stageData.options[origIdx];
    const btn=document.createElement('button');
    btn.className='opt-btn';
    btn.textContent=opt.text;
    // Visual state derived entirely from game state - no live list indexing
    if(state.disabledOpts.includes(origIdx)){
      btn.disabled=true;
      btn.classList.add('wrong');
    }
    if(state.stageComplete && opt.correct){
      btn.classList.add('correct');
    }
    if(state.stageComplete){
      btn.disabled=true;
    }
    btn.addEventListener('click',()=>handleOption(origIdx));
    grid.appendChild(btn);
  });
}

function handleOption(idx){
  const round=ROUNDS[state.round];
  const stageData=round.stages[state.stage];
  const opt=stageData.options[idx];
  const fb=document.getElementById('feedbackCard');

  if(opt.correct){
    state.stageComplete=true;
    renderOptions();

    const firstAttempt=state.disabledOpts.length===0;
    if(firstAttempt){state.score++;updateScore();}

    animCorrectKey(state.round);
    flash('green');
    setMarv('fbMarvImg','thumbsup');
    document.getElementById('fbLabel').textContent='CORRECT';
    document.getElementById('fbBody').textContent=opt.fb;
    fb.className='feedback-card show-correct';

    const isLastStage=state.stage===round.stages.length-1;
    if(!isLastStage){
      const nb=document.getElementById('nextBtn');
      nb.textContent='Next Stage';nb.className='next-btn show';
    } else {
      // Mark final stage pill as done immediately
      const pills=document.querySelectorAll('.stage-btn');
      if(pills[state.stage]) { pills[state.stage].className='stage-btn done'; }
      // Round complete - small sat boost
      SAT=Math.min(SAT_MAX,SAT+1);
      updateSatBar();
      setTimeout(()=>{
        animRescue(state.round);
        document.getElementById('rescueOverlay').classList.add('show');
        state.roundComplete=true;
        const nb=document.getElementById('nextBtn');
        nb.textContent=state.round<ROUNDS.length-1?'Next Round':'See Results';
        nb.className='next-btn show';
      },700);
    }
  } else {
    state.disabledOpts.push(idx);
    renderOptions();

    // Animate surface if sand/technique stage
    if(opt.animType==='deepScratch')animDeepScratch(state.round);
    else if(opt.animType==='heatDistort')animHeatDistort(state.round);
    else if(opt.animType==='crossGrain')animCrossGrain(state.round);
    else if(opt.animType==='overAbrasion')animOverAbrasion(state.round);

    flash('red');
    SAT=Math.max(0,SAT-1);
    updateSatBar();
    setMarv('fbMarvImg','angry');
    document.getElementById('fbLabel').textContent='WRONG';
    document.getElementById('fbBody').textContent=opt.fb;
    fb.className='feedback-card show-wrong';

    if(SAT<=0){
      setTimeout(showGameOver,600);
    }
  }
}

function handleNext(){
  const round=ROUNDS[state.round];
  stopAnim();
  if(state.roundComplete){
    if(state.round<ROUNDS.length-1){state.round++;loadRound();window.scrollTo(0,0);}
    else showCompletion();
  } else if(state.stageComplete&&state.stage<round.stages.length-1){
    state.stage++;loadStage();
  }
}

// ── GAME OVER ─────────────────────────────────────────
function showGameOver(){
  document.getElementById('screenGame').classList.remove('active');
  document.getElementById('screenGameOver').classList.add('active');
  setMarv('goMarvImg','angry');
  document.getElementById('goMsg').textContent=
    'The customer has had enough. Too many mistakes on the '+ROUNDS[state.round].substrate.toLowerCase()+'. Let\'s go again - you have seen what goes wrong now.';
}

function retryRound(){
  document.getElementById('screenGameOver').classList.remove('active');
  document.getElementById('screenGame').classList.add('active');
  SAT=10;updateSatBar();
  loadRound();
}

// ── COMPLETION ────────────────────────────────────────
function showCompletion(){
  document.getElementById('screenGame').classList.remove('active');
  document.getElementById('screenComplete').classList.add('active');
  for(let i=0;i<5;i++){const d=document.getElementById('dot'+i);if(d)d.className='rdot done';}

  document.getElementById('finalScore').textContent=state.score;
  setTimeout(()=>{
    const circ=289;
    document.getElementById('ringFill').style.strokeDashoffset=circ-(state.score/20)*circ;
  },250);

  let msg,speech;
  if(state.score===20){msg='Perfect. Every decision correct first time. You are ready for the practical session.';speech=MARV_COMPLETION_SPEECH.perfect;}
  else if(state.score>=16){msg='Strong result. Review any rounds you retried before your practical session.';speech=MARV_COMPLETION_SPEECH.high;}
  else if(state.score>=12){msg='Good progress. Check the grit reference card before your practical session.';speech=MARV_COMPLETION_SPEECH.mid;}
  else{msg='Review the reference card and revisit Lesson 4 before the practical.';speech=MARV_COMPLETION_SPEECH.low;}

  document.getElementById('perfMsg').textContent=msg;
  document.getElementById('compSpeech').textContent=speech;
  setMarv('compMarvImg','triumph');

  // Save high score
  const prev = getHighScore();
  if(state.score > prev) {
    saveHighScore(state.score);
    const badge = document.getElementById('newBestBadge');
    if(badge) badge.classList.add('show');
  }
  console.log('complete sent');
  window.parent.postMessage({type:'complete'},'*');
}

// ── INIT ─────────────────────────────────────────────
// intro marv handled by splash screen img tag
preloadSurfaceImages();
updateSplashHighScore();
resizeCanvas();

window.addEventListener('resize',()=>{
  if(document.getElementById('screenGame').classList.contains('active')){
    resizeCanvas();
    const r=ROUNDS[state.round];
    drawSurface(r.surfaceType,r.surfaceColor,false);
  }
});
</script>
