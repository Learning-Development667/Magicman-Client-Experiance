<script>
const SURFACE_IMGS = {
  acrylic_dmg: "data:image/png;base64,",
  acrylic_rep: "data:image/png;base64,",
  upvc_dmg: "data:image/png;base64,",
  upvc_rep: "data:image/png;base64,",
  timber_dmg: "data:image/png;base64,",
  timber_rep: "data:image/png;base64,",
  enamel_dmg: "data:image/png;base64,",
  enamel_rep: "data:image/png;base64,",
  steel_dmg: "data:image/png;base64,",
  steel_rep: "data:image/png;base64,",
};


const SURF_TYPE_MAP = {
  acrylic: { dmg: 'acrylic_dmg', rep: 'acrylic_rep' },
  upvc:    { dmg: 'upvc_dmg',    rep: 'upvc_rep' },
  timber:  { dmg: 'timber_dmg',  rep: 'timber_rep' },
  enamel:  { dmg: 'enamel_dmg',  rep: 'enamel_rep' },
  steel:   { dmg: 'steel_dmg',   rep: 'steel_rep' },
};

// Preloaded Image objects
const SURF_LOADED = {};
function preloadSurfaceImages() {
  Object.entries(SURFACE_IMGS).forEach(([key, src]) => {
    const img = new Image();
    img.src = src;
    SURF_LOADED[key] = img;
  });
}

const IMGS = {
  assess: "data:image/png;base64,",
  triumph: "data:image/png;base64,",
  angry: "data:image/png;base64,",
  confident: "data:image/png;base64,",
  thumbsup: "data:image/png;base64,",
  instruct: "data:image/png;base64,",
  nervous: "data:image/png;base64,",
};



// ── SATISFACTION BAR ──────────────────────────────────
// 10 levels, starts at 10. Each wrong answer -1. Each correct +0 (balanced).
// Stage rescue (both stages correct): +1 back.
// 0 = customer lost, game over.
let SAT = 10;
const SAT_MAX = 10;

function satPct() { return Math.max(0, (SAT / SAT_MAX) * 100); }

function updateSatBar() {
  const pct = satPct();
  const fill = document.getElementById('satFill');
  if (!fill) return;
  fill.style.width = pct + '%';
  // Update MARV frame to reflect satisfaction if game screen active
  if(document.getElementById('screenGame') && document.getElementById('screenGame').classList.contains('active')) {
    const stageData = ROUNDS[state.round] && ROUNDS[state.round].stages[state.stage];
    if(stageData && !state.stageComplete) {
      setMarv('marvFrame', getMarvKey(stageData.type, SAT));
    }
  }
  if (pct > 60) {
    fill.style.background = 'linear-gradient(90deg,#93C847,#AED284)';
  } else if (pct > 30) {
    fill.style.background = 'linear-gradient(90deg,#EF9F27,#FAC775)';
  } else {
    fill.style.background = 'linear-gradient(90deg,#E24B4A,#f07070)';
  }
}

// ── GAME DATA ─────────────────────────────────────────
const ROUNDS = [
  {
    substrate:'ACRYLIC BATH', surfaceType:'acrylic', surfaceColor:'#F5ECD7',
    stages:[
      { type:'clean', label:'Clean',
        prompt:'There is silicone sealant residue around the scratch zone from a recent re-seal. How do you clean this area before repair?',
        marv:"Acrylic bath - fine scratches, but there is silicone residue around the repair zone from a recent re-seal. That changes what you need to use. What is your approach?",
        options:[
          {text:'Silicone remover applied to the affected area, then follow with an IPA wipe and allow to dry', correct:true, fb:'Correct. IPA alone does not break down silicone. You need a dedicated silicone remover first, then follow with IPA to remove any remaining residue before abrasive work.'},
          {text:'IPA wipe only - it is strong enough to remove silicone', correct:false, fb:"IPA does not break down silicone sealant residue. Wiping over it with IPA spreads the silicone thinly across the surface - invisible to the eye but enough to cause fisheyes and coating failure."},
          {text:'Scrape the silicone off with a blade, then proceed to abrasion', correct:false, fb:"Scraping removes the bulk but leaves silicone traces in the surface scratches. Without a silicone remover and IPA wipe, contamination remains and the coating will fail."},
          {text:'Bathroom cleaning spray - it cuts through sealant residue', correct:false, fb:"Bathroom cleaners do not break down silicone. They also leave surfactant residue on the acrylic surface that causes the same adhesion problems you were trying to solve."}
        ]
      },
      { type:'mask', label:'Mask',
        prompt:'The bath has a chrome overflow fitting and a tiled surround within 100mm of the repair. How do you mask this repair?',
        marv:"Good. The chrome overflow and tiled surround are right next to this repair. Overspray on either of those is a problem. How are you masking?",
        options:[
          {text:'Low-tack tape 50mm beyond the repair, covering the chrome overflow fitting and protecting the tile grout lines', correct:true, fb:'Correct. Chrome fittings and tile grout are both vulnerable to overspray. Low-tack tape protects both without leaving adhesive residue on the chrome or acrylic.'},
          {text:'Standard masking tape across the repair boundary only', correct:false, fb:"Standard tape is too aggressive for acrylic and chrome. It leaves adhesive residue on both surfaces. Use low-tack tape throughout, and extend the boundary to cover the overflow fitting."},
          {text:'Tape the repair boundary only - the chrome fitting is far enough away', correct:false, fb:"100mm is not far enough. Coating overspray travels and the chrome fitting needs explicit protection. Tape it directly and do not rely on distance."},
          {text:'Cover the full bath panel with plastic sheeting secured with tape', correct:false, fb:"Full sheeting is excessive and makes it impossible to see your repair boundary clearly. Controlled local masking of the repair zone and adjacent fittings is the right approach."}
        ]
      },
      { type:'sand', label:'Sand',
        prompt:'Select the correct starting grit sequence for this surface.',
        marv:"Masked up. Now the abrasive prep - this is where most people damage acrylic. Choose carefully.",
        options:[
          {text:'P80 to P120 - coarse to medium', correct:false, animType:'deepScratch', fb:'P80 on acrylic causes deep scratches that show through the coating and can worsen any crazing. Far too aggressive.'},
          {text:'P800 to P1200 - light progressive sequence', correct:true, fb:'Correct. P800 to P1200 creates a consistent fine key without cutting into the acrylic surface.'},
          {text:'P240 - medium grit only', correct:false, animType:'deepScratch', fb:'P240 is too coarse for acrylic. It creates deep scratches requiring significantly more work to blend.'},
          {text:'P2000 only - very fine', correct:false, animType:'overAbrasion', fb:'P2000 alone will not create sufficient mechanical key for reliable coating adhesion.'}
        ]
      },
      { type:'technique', label:'Technique',
        prompt:'Select the correct technique approach for this substrate.',
        marv:"Right grit. Now the technique. You are nearly there - do not throw it away here.",
        options:[
          {text:'Machine sanding at speed across the full surface', correct:false, animType:'heatDistort', fb:'Machine sanding on acrylic generates heat rapidly - abrasive gumming, distortion, potential crazing. Hand sanding only.'},
          {text:'Heavy pressure, fast strokes to cover quickly', correct:false, animType:'overAbrasion', fb:'Heavy pressure causes uneven keying and over-abrasion at contact points. Consistent light pressure is essential.'},
          {text:'Light consistent pressure - hand sanding - short passes working with the surface', correct:true, fb:'Correct. Light pressure, hand sanding, and short controlled passes protect the acrylic while creating an even key.'},
          {text:'Circular random orbital motion for even coverage', correct:false, animType:'heatDistort', fb:'Random orbital generates heat and circular marks on acrylic. Use controlled linear hand sanding.'}
        ]
      }
    ]
  },
  {
    substrate:'UPVC PANEL', surfaceType:'upvc', surfaceColor:'#EFEFEF',
    stages:[
      { type:'clean', label:'Clean',
        prompt:'This door panel has wax polish build-up from regular maintenance. There is a visible smear across the repair area. How do you clean it?',
        marv:"uPVC door panel - scuffs across the surface. The customer keeps it well maintained with polish, which means wax build-up. That is your first problem to solve.",
        options:[
          {text:'IPA wipe across the full repair area including the wax smear, allow to dry completely', correct:true, fb:'Correct. IPA cuts through wax polish residue on uPVC effectively. A thorough wipe removing all traces of the smear, followed by full drying, gives you a clean surface ready for abrasion.'},
          {text:'uPVC cream cleaner to remove the wax - it is designed for this surface', correct:false, fb:"uPVC cream cleaners contain wax themselves. Using one to remove wax simply replaces one contamination with another. They are maintenance products, not pre-repair cleaners."},
          {text:'Warm water and washing-up liquid to cut through the wax build-up', correct:false, fb:"Washing-up liquid leaves a surfactant film on the uPVC surface that is just as problematic as the original wax. It also does not fully remove wax residue from a matt or lightly textured surface."},
          {text:'Lightly sand the wax smear off before chemical cleaning', correct:false, fb:"Sanding through wax embeds it into the substrate and into the abrasive. Clean the wax off with IPA first - then abrade once the surface is fully dry."}
        ]
      },
      { type:'mask', label:'Mask',
        prompt:'The panel has rubber door seals on three sides and a letter box fitting within the repair zone. How do you mask this repair?',
        marv:"The door seals and letter box fitting are right in the working area. Abrasive dust in a rubber seal causes real problems. How are you masking this?",
        options:[
          {text:'Low-tack tape 50mm beyond the repair boundary, covering all three rubber seals and the letter box fitting completely', correct:true, fb:'Correct. Rubber seals trap abrasive dust and are damaged by coating overspray. The letter box fitting needs full coverage. Low-tack tape protects both without leaving residue on the uPVC.'},
          {text:'Tape the repair boundary and fold a cloth over the letter box fitting', correct:false, fb:"A cloth over the letter box is not controlled masking. It moves during abrasive work and leaves gaps. Tape it properly with low-tack tape covering the full fitting."},
          {text:'Tape the repair boundary only - seals and fittings are tough enough', correct:false, fb:"Rubber seals trap abrasive grit and once contaminated they are extremely difficult to clean out. Overspray on the letter box fitting is a customer complaint waiting to happen. Mask everything."},
          {text:'Cover the full door with a dust sheet before starting', correct:false, fb:"A full door dust sheet does not create a controlled repair boundary and moves around during abrasive work. Use precise low-tack tape masking on the repair zone and all adjacent vulnerable areas."}
        ]
      },
      { type:'sand', label:'Sand',
        prompt:'Select the correct starting grit sequence for uPVC.',
