// ── CANVAS ──────────────────────────────────────────
const canvas = document.getElementById('surfaceCanvas');
const ctx = canvas.getContext('2d');
let animFrame = null;

function resizeCanvas() {
  const dpr = window.devicePixelRatio||1;
  const w = canvas.offsetWidth;
  canvas.width = w*dpr; canvas.height = 140*dpr;
  canvas.style.height = '140px';
  ctx.scale(dpr,dpr);
}
function W() { return canvas.offsetWidth||680; }
const CH = 140;

function drawSurface(type, color, useRepaired) {
  const w = W();
  ctx.clearRect(0, 0, w, CH);
  const map = SURF_TYPE_MAP[type];
  const key = map ? (useRepaired ? map.rep : map.dmg) : null;
  const img = key ? SURF_LOADED[key] : null;
  if (img && img.complete && img.naturalWidth > 0) {
    ctx.drawImage(img, 0, 0, w, CH);
  } else {
    // Fallback CSS gradient while image loads
    const g = ctx.createLinearGradient(0, 0, 0, CH);
    if(type==='acrylic'){g.addColorStop(0,'#FDF6E8');g.addColorStop(1,'#EDD9B0');}
    else if(type==='upvc'){g.addColorStop(0,'#F8F8F8');g.addColorStop(1,'#E0E0E0');}
    else if(type==='timber'){g.addColorStop(0,'#D4B07A');g.addColorStop(1,'#B08040');}
    else if(type==='enamel'){g.addColorStop(0,'#FFFFFF');g.addColorStop(1,'#E8E8E6');}
    else{g.addColorStop(0,'#D8DDE0');g.addColorStop(1,'#A8ADB0');}
    ctx.fillStyle = g;
    ctx.fillRect(0, 0, w, CH);
  }
}

function stopAnim(){if(animFrame){cancelAnimationFrame(animFrame);animFrame=null;}}

function animDeepScratch(round){
  stopAnim();const r=ROUNDS[round];const w=W();let p=0;
  const s=Array.from({length:7},()=>({x:w*(0.1+Math.random()*0.8),y:CH*(0.15+Math.random()*0.7),a:Math.random()*Math.PI,l:35+Math.random()*55}));
  function f(){drawSurface(r.surfaceType,r.surfaceColor,false);p=Math.min(p+0.035,1);const e=1-Math.pow(1-p,3);
    s.forEach(sc=>{ctx.strokeStyle=`rgba(30,15,5,${0.75*e})`;ctx.lineWidth=2+e*3;ctx.lineCap='round';
      ctx.beginPath();ctx.moveTo(sc.x-Math.cos(sc.a)*sc.l*e,sc.y-Math.sin(sc.a)*sc.l*e);
      ctx.lineTo(sc.x+Math.cos(sc.a)*sc.l*e,sc.y+Math.sin(sc.a)*sc.l*e);ctx.stroke();});
    if(p<1)animFrame=requestAnimationFrame(f);}
  animFrame=requestAnimationFrame(f);
}
function animHeatDistort(round){
  stopAnim();const r=ROUNDS[round];const w=W();let p=0;
  function f(){drawSurface(r.surfaceType,r.surfaceColor,false);p=Math.min(p+0.028,1);const e=1-Math.pow(1-p,2);
    for(let i=0;i<4;i++){const px=w*(0.12+i*0.22),py=CH*0.5;const g=ctx.createRadialGradient(px,py,0,px,py,40*e);
      g.addColorStop(0,`rgba(255,215,80,${0.4*e})`);g.addColorStop(0.5,`rgba(210,170,50,${0.2*e})`);g.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=g;ctx.fillRect(0,0,w,CH);}
    for(let i=0;i<6;i++){ctx.strokeStyle=`rgba(170,130,40,${0.4*e})`;ctx.lineWidth=2+i*0.4;ctx.lineCap='round';
      ctx.beginPath();const sy=CH*(0.2+i*0.11);ctx.moveTo(w*0.05,sy);
      ctx.bezierCurveTo(w*0.3,sy-10*e,w*0.7,sy+8*e,w*0.95,sy);ctx.stroke();}
    if(p<1)animFrame=requestAnimationFrame(f);}
  animFrame=requestAnimationFrame(f);
}
function animCrossGrain(round){
  stopAnim();const r=ROUNDS[round];const w=W();let p=0;
  const arcs=Array.from({length:6},()=>({cx:w*(0.1+Math.random()*0.8),cy:CH*(0.15+Math.random()*0.7),rad:18+Math.random()*32,start:Math.random()*Math.PI*2}));
  function f(){drawSurface(r.surfaceType,r.surfaceColor,false);p=Math.min(p+0.032,1);const e=1-Math.pow(1-p,3);
    arcs.forEach(a=>{ctx.strokeStyle=`rgba(50,35,15,${0.7*e})`;ctx.lineWidth=1.5;ctx.lineCap='round';
      ctx.beginPath();ctx.arc(a.cx,a.cy,a.rad,a.start,a.start+Math.PI*1.7*e);ctx.stroke();});
    for(let i=0;i<5;i++){ctx.strokeStyle=`rgba(40,25,10,${0.5*e})`;ctx.lineWidth=1;
      ctx.beginPath();ctx.moveTo(w*(0.08+i*0.2),0);ctx.lineTo(w*(0.08+i*0.2)+70*e,CH);ctx.stroke();}
    if(p<1)animFrame=requestAnimationFrame(f);}
  animFrame=requestAnimationFrame(f);
}
function animOverAbrasion(round){
  stopAnim();const r=ROUNDS[round];const w=W();let p=0;
  const pts=Array.from({length:7},()=>({x:w*(0.08+Math.random()*0.84),y:CH*(0.08+Math.random()*0.84),rx:18+Math.random()*38,ry:10+Math.random()*18}));
  function f(){drawSurface(r.surfaceType,r.surfaceColor,false);p=Math.min(p+0.032,1);const e=1-Math.pow(1-p,3);
    pts.forEach(pt=>{const g=ctx.createRadialGradient(pt.x,pt.y,0,pt.x,pt.y,pt.rx*e);
      g.addColorStop(0,`rgba(195,155,90,${0.55*e})`);g.addColorStop(0.6,`rgba(175,135,70,${0.3*e})`);g.addColorStop(1,'rgba(0,0,0,0)');
      ctx.save();ctx.scale(1,pt.ry/pt.rx);ctx.fillStyle=g;ctx.beginPath();
      ctx.arc(pt.x,pt.y*(pt.rx/pt.ry),pt.rx*e,0,Math.PI*2);ctx.fill();ctx.restore();});
    if(p<1)animFrame=requestAnimationFrame(f);}
  animFrame=requestAnimationFrame(f);
}
function animCorrectKey(round){
  stopAnim();const r=ROUNDS[round];const w=W();let p=0;
  function f(){drawSurface(r.surfaceType,r.surfaceColor,false);p=Math.min(p+0.022,1);const e=1-Math.pow(1-p,2);
    const lc=Math.floor(45*e);
    for(let i=0;i<lc;i++){const y=(CH/44)*i;ctx.strokeStyle=`rgba(70,55,35,${0.12*e})`;ctx.lineWidth=0.5;
      ctx.beginPath();ctx.moveTo(0,y+Math.random());ctx.lineTo(w,y+Math.random());ctx.stroke();}
    ctx.fillStyle=`rgba(210,215,210,${0.1*e})`;ctx.fillRect(0,0,w,CH);
    if(p<1)animFrame=requestAnimationFrame(f);}
  animFrame=requestAnimationFrame(f);
}
function animRescue(round){
  stopAnim();
  const r = ROUNDS[round];
  const w = W();
  let p = 0;
  function f(){
    // Draw damaged surface underneath
    drawSurface(r.surfaceType, r.surfaceColor, false);
    // Crossfade repaired surface on top
    p = Math.min(p + 0.018, 1);
    const e = 1 - Math.pow(1-p, 2);
    const map = SURF_TYPE_MAP[r.surfaceType];
    const repImg = map ? SURF_LOADED[map.rep] : null;
    if (repImg && repImg.complete && repImg.naturalWidth > 0) {
      ctx.globalAlpha = e;
      ctx.drawImage(repImg, 0, 0, w, CH);
      ctx.globalAlpha = 1;
    } else {
      // Fallback green wash
      ctx.fillStyle = `rgba(200,235,200,${0.6*e})`;
      ctx.fillRect(0, 0, w, CH);
    }
    if(p < 1) animFrame = requestAnimationFrame(f);
  }
  animFrame = requestAnimationFrame(f);
}

// ── FLASH ────────────────────────────────────────────
function flash(type){
  const el=document.getElementById('flashEl');
  el.className=`flash ${type} on`;
  setTimeout(()=>{el.className=`flash ${type}`;},160);
}

// ── SCORE ────────────────────────────────────────────
function updateScore(){
  const el=document.getElementById('scoreDisplay');
  let cur=parseInt(el.textContent)||0;
  if(cur<state.score){
    const iv=setInterval(()=>{cur++;el.textContent=String(cur).padStart(2,'0');if(cur>=state.score)clearInterval(iv);},60);
  } else {
    el.textContent=String(state.score).padStart(2,'0');
  }
}

// ── DOTS ─────────────────────────────────────────────
function updateDots(){
  for(let i=0;i<5;i++){
    const d=document.getElementById('dot'+i);
    if(!d)return;
    d.className='rdot';
    if(i<state.round)d.classList.add('done');
    else if(i===state.round)d.classList.add('active');
  }
}

